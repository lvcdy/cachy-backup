// 窗口规则配置
// 参考配置来源：https://github.com/SHORiN-KiWATA/shorin-niri

// noctalia v5 背景层规则
layer-rule {
    match namespace="awww-daemonoverview"
    match namespace="swww-daemonoverview"
    place-within-backdrop true
}

// 全局窗口规则
window-rule {
    // 全局透明度
    opacity 0.97
    // 圆角
    geometry-corner-radius 8
    // 去掉超出圆角的窗口内容
    clip-to-geometry true
    // 禁止边框画到背景里
    draw-border-with-background false
}

// 取消图片预览、视频播放器之类的透明度，并且以浮动模式打开
window-rule {
    match title="图片查看器"
    match title="画中画"
    match title="图片和视频"
    match title="视频播放器"
    open-floating true
    opacity 1.0
}

// 取消特定软件的背景透明度
window-rule {
    match app-id="mpv"
    match app-id="celluloid"
    match app-id="virt-manager"
    opacity 1.0
}

// 以浮动模式打开的软件
window-rule {
    match app-id="com.gabm.satty"
    match app-id="media_info"
    match app-id="video2gif"
    match app-id="floating-term"
    match app-id="nm-connection-editor"
    match app-id="niri-quick-switch"
    match app-id=r#"firefox$"# title="^Picture-in-Picture$"
    match app-id="blueberry.py" title="蓝牙"
    match app-id="blueman-manager"
    match app-id="flameshot"
    match app-id="com.github.hluk.copyq"
    match app-id="be.alexandervanhee.gradia"
    match app-id="org.pulseaudio.pavucontrol" title="音量控制"
    match app-id="org.gnome.clocks" title="时钟"
    match app-id="fcitx" title="Fcitx5 Input Window"
    match app-id="org.gnome.FileRoller"
    match app-id="thunar" title="文件操作进度"
    match app-id="waypaper"
    match app-id="clipse-gui"
    match title="群聊的聊天记录"
    match title="聊天记录"
    match title="群相册"
    match title="日历"
    match title="重命名"
    match app-id="btrfs-assistant"
    match app-id="markpix"
    match title="Steam 设置"
    match title="另存为"
    match app-id="better_control.py"
    match app-id="niri-hotkey-menu"
    match app-id="io.github.fabrialberio.pinapp"
    match app-id="org.gnome.Calculator"
    match app-id="floating-mpv"
    match app-id="thunar"
    match app-id="io.github.shorin.proton_wrapper_configure"
    match app-id="io.github.shorin.proton_wrapper_manager"
    open-floating true
}

// 开启后不聚焦的窗口
window-rule {
    match app-id="QQ" title="资料卡"
    match app-id="QQ" title="天气"
    open-focused false
}

// Steam 好友列表
window-rule {
    match app-id="steam" title="Friends List"
    match app-id="steam" title="好友列表"
    default-column-width { proportion 0.20; }
}

// 快速终端和笔记
window-rule {
    match app-id="notebook"
    match app-id="quickterminal"
    open-floating true
    default-floating-position x=20 y=20 relative-to="top"
}

// 蓝牙和网络 TUI
window-rule {
    match app-id="bluetui"
    match app-id="impala"
    match app-id="network-tui"
    default-column-width { fixed 800; }
    default-window-height { fixed 800; }
    open-floating true
}

// 剪贴板 TUI
window-rule {
    match app-id="clipse"
    default-column-width { fixed 625; }
    default-window-height { fixed 700; }
    open-floating true
}

// Waydroid 调整
window-rule {
    match title="gsr ui"
    match app-id="waydroid"
    open-fullscreen true
    open-floating true
    focus-ring {
        off
    }
    shadow {
        off
    }
}

// WezTerm 窗口规则
window-rule {
    match app-id=r#"^org\.wezfurlong\.wezterm$"#
    default-column-width {}
}

// Steam 好友弹窗修复
window-rule {
    match app-id="steam" title=r#"^notificationtoasts_\d+_desktop$"#
    default-floating-position x=10 y=10 relative-to="bottom-right"
    open-focused false
}

// 屏幕录制保护
window-rule {
    match app-id=r#"^org\.keepassxc\.KeePassXC$"#
    match app-id=r#"^org\.gnome\.World\.Secrets$"#
    match app-id="wechat"
    match app-id="^WebApp-GeminiAiStudio1566$"
    block-out-from "screen-capture"
}
